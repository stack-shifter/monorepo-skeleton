# Copy this to .env and fill in your values
# Never commit .env

# Postgres connection string
# For local dev: postgres://postgres:password@localhost:5432/realestate_dev
# For PgBouncer: postgres://postgres:password@localhost:6432/realestate_dev?pgbouncer=true
DATABASE_URL=postgres://postgres:password@localhost:5432/realestate_dev

# Express API port
PORT=3001

# Next.js UI port
UI_PORT=3000

# Server-side API base URL used by the Next.js app
API_BASE_URL=http://localhost:3001/api

# Optional CDK overrides for ECS container images and registry credentials
CDK_API_IMAGE_URI=ghcr.io/example/saas/api:latest
CDK_UI_IMAGE_URI=ghcr.io/example/saas/ui:latest
CDK_GHCR_CREDENTIALS_SECRET_NAME=ghcr/pull-credentials
